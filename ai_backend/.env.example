# AI PCB Assistant — Environment Configuration
# Copy this file to .env and fill in your values.
# The backend loads .env automatically on startup.

# ── LLM Backend (pick ONE) ────────────────────────────────────────────────────

# Option 1: OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Option 2: Groq (free tier, very fast)
# OPENAI_API_KEY=gsk_...
# OPENAI_API_BASE=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama3-8b-8192

# Option 3: Together AI
# OPENAI_API_KEY=...
# OPENAI_API_BASE=https://api.together.xyz/v1
# OPENAI_MODEL=mistralai/Mixtral-8x7B-Instruct-v0.1

# Option 4: Ollama (local, no key needed — just run: ollama run llama3)
# No env vars needed, auto-detected.

# Option 5: Local GGUF model (fully offline)
# LLM_GGUF_MODEL=deepseek-coder-6.7b-instruct.Q5_K_M.gguf
# MODELS_DIR=/path/to/your/models

# ── Server ────────────────────────────────────────────────────────────────────
# HOST=127.0.0.1
# PORT=8765
